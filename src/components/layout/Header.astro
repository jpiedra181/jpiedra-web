---
//@ts-nocheck
import type { Lang } from "../../types"
import { useTranslations } from "../../i18n/utils"
import LanguageSwitcher from "../ui/LanguageSwitcher.astro"

interface Props {
    lang: Lang
}

const { lang } = Astro.props
const t = useTranslations(lang)

const basePath = lang === "es" ? "/" : "/en/"

const auditHref =
    lang === "es" ? "/auditoria-accesibilidad" : "/en/accessibility-audit"
const blogHref = lang === "es" ? "/blog" : "/en/blog"
const contactHref = "/te-aplica-ley-11-2023"

const navItems = [
    { href: contactHref, label: t.nav.law },
    { href: blogHref, label: t.nav.blog },
]
---

<header
    id="site-header"
    class="fixed top-0 left-0 w-full z-50 transition-all duration-300"
>
    <div
        class="max-w-7xl mx-auto px-6 lg:px-8 flex items-center justify-between h-20"
    >
        <!-- Logo -->
        <a href={lang === "es" ? "/" : "/en/"} class="relative z-10 group">
            <span
                class="font-heading text-3xl text-text-primary tracking-tight"
            >
                J<span class="text-accent">.</span>P
            </span>
        </a>

        <!-- Desktop Nav -->
        <nav
            aria-label={lang === "es"
                ? "Navegación principal"
                : "Main navigation"}
            class="hidden lg:flex items-center gap-8"
        >
            {
                navItems.map((item) => (
                    <a
                        href={item.href}
                        class="text-sm text-text-secondary hover:text-accent transition-colors duration-200 tracking-wide uppercase"
                    >
                        {item.label}
                    </a>
                ))
            }
            <!-- <LanguageSwitcher lang={lang} /> -->
            <a
                href={auditHref}
                class="inline-flex items-center font-body font-medium text-sm tracking-wide transition-all duration-300 rounded-full bg-accent text-bg-primary hover:bg-accent-hover px-5 py-2.5 hover:shadow-lg hover:shadow-accent/20 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white"
            >
                {t.nav.audit}
            </a>
        </nav>
    </div>
</header>

<!-- Mobile Menu Button -->
<button
    id="mobile-menu-btn"
    class="lg:hidden fixed top-0 right-0 z-[60] w-10 h-10 flex items-center justify-center mr-6 mt-5"
    aria-label="Menu"
    aria-expanded="false"
>
    <div class="relative w-6 h-5">
        <span
            class="mobile-menu-line absolute left-0 w-full h-[2px] bg-text-primary transition-all duration-300 ease-in-out top-0"
        ></span>
        <span
            class="mobile-menu-line absolute left-0 w-full h-[2px] bg-text-primary transition-all duration-300 ease-in-out top-1/2 -translate-y-1/2"
        ></span>
        <span
            class="mobile-menu-line absolute left-0 w-2/3 h-[2px] bg-text-primary transition-all duration-300 ease-in-out bottom-0 right-0 left-auto"
        ></span>
    </div>
</button>

<!-- Mobile Menu -->
<div
    id="mobile-menu"
    class="fixed inset-0 z-[55] bg-bg-primary/98 backdrop-blur-xl flex flex-col items-center justify-center gap-8 opacity-0 pointer-events-none transition-opacity duration-300 lg:hidden"
>
    {
        navItems.map((item) => (
            <a
                href={item.href}
                class="mobile-nav-link text-2xl font-heading text-text-primary hover:text-accent transition-colors duration-200"
            >
                {item.label}
            </a>
        ))
    }
    <a
        href={auditHref}
        class="mobile-nav-link inline-flex items-center font-body font-medium text-base tracking-wide transition-all duration-300 rounded-full bg-accent text-bg-primary hover:bg-accent-hover px-7 py-3 mt-2"
    >
        {t.nav.audit}
    </a>
    <!-- <div class="mt-4">
        <LanguageSwitcher lang={lang} />
    </div> -->
</div>

<script>
    const header = document.getElementById("site-header")!
    const mobileBtn = document.getElementById("mobile-menu-btn")!
    const mobileMenu = document.getElementById("mobile-menu")!
    const lines = mobileBtn.querySelectorAll(".mobile-menu-line")
    const mobileLinks = mobileMenu.querySelectorAll(".mobile-nav-link")
    const mainEl = document.getElementById("main-content")
    const footerEl = document.querySelector("footer")
    let menuOpen = false

    function setBackgroundInert(on: boolean) {
        const targets = [header, mainEl, footerEl]
        for (const el of targets) {
            if (!el) continue
            if (on) el.setAttribute("inert", "")
            else el.removeAttribute("inert")
        }
    }

    function toggleMenu() {
        menuOpen = !menuOpen
        mobileBtn.setAttribute("aria-expanded", String(menuOpen))

        if (menuOpen) {
            mobileMenu.classList.remove("opacity-0", "pointer-events-none")
            mobileMenu.classList.add("opacity-100", "pointer-events-auto")
            lines[0].classList.add("!top-1/2", "-translate-y-1/2", "rotate-45")
            lines[1].classList.add("opacity-0", "scale-x-0")
            lines[2].classList.add(
                "!bottom-auto",
                "!top-1/2",
                "-translate-y-1/2",
                "-rotate-45",
                "!w-full",
                "!left-0",
            )
            document.body.style.overflow = "hidden"
            setBackgroundInert(true)
        } else {
            mobileMenu.classList.add("opacity-0", "pointer-events-none")
            mobileMenu.classList.remove("opacity-100", "pointer-events-auto")
            lines[0].classList.remove(
                "!top-1/2",
                "-translate-y-1/2",
                "rotate-45",
            )
            lines[1].classList.remove("opacity-0", "scale-x-0")
            lines[2].classList.remove(
                "!bottom-auto",
                "!top-1/2",
                "-translate-y-1/2",
                "-rotate-45",
                "!w-full",
                "!left-0",
            )
            document.body.style.overflow = ""
            setBackgroundInert(false)
        }
    }

    mobileBtn.addEventListener("click", toggleMenu)
    mobileLinks.forEach((link) =>
        link.addEventListener("click", () => {
            if (menuOpen) toggleMenu()
        }),
    )

    // Escape cierra el menú y devuelve el foco al botón hamburguesa.
    // Tab/Shift+Tab quedan atrapados entre la hamburguesa y los enlaces del menú.
    document.addEventListener("keydown", (e) => {
        if (!menuOpen) return

        if (e.key === "Escape") {
            toggleMenu()
            mobileBtn.focus()
            return
        }

        if (e.key === "Tab") {
            const inMenu = Array.from(
                mobileMenu.querySelectorAll<HTMLElement>(
                    'a, button, [tabindex]:not([tabindex="-1"])',
                ),
            )
            const focusables = [mobileBtn, ...inMenu]
            if (focusables.length === 0) return
            const first = focusables[0]
            const last = focusables[focusables.length - 1]
            if (e.shiftKey && document.activeElement === first) {
                e.preventDefault()
                last.focus()
            } else if (!e.shiftKey && document.activeElement === last) {
                e.preventDefault()
                first.focus()
            }
        }
    })

    window.addEventListener("scroll", () => {
        if (window.scrollY > 50) {
            header.classList.add(
                "bg-bg-primary/80",
                "backdrop-blur-xl",
                "border-b",
                "border-border",
            )
        } else {
            header.classList.remove(
                "bg-bg-primary/80",
                "backdrop-blur-xl",
                "border-b",
                "border-border",
            )
        }
    })
</script>
