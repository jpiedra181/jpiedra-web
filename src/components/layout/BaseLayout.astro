---
import type { Lang } from "../../types"
import { siteConfig } from "../../config/site"
import Header from "./Header.astro"
import Footer from "./Footer.astro"
import "../../styles/global.css"

interface Props {
    lang: Lang
    title?: string
    description?: string
    ogImage?: string
    ogImageAlt?: string
}

const { lang, title, description, ogImage, ogImageAlt } = Astro.props

// Default title and description based on language
const pageTitle =
    title ||
    (lang === "es"
        ? "Javier Piedra - Accesibilidad web según Ley 11/2023 y WCAG 2.1 AA"
        : "Javier Piedra - Web accessibility according to Law 11/2023 and WCAG 2.1 AA")

const pageDescription =
    description ||
    (lang === "es"
        ? "Audito y construyo webs accesibles según la Ley 11/2023 y WCAG 2.1 AA. Para empresas obligadas por la European Accessibility Act. Sin humo, sin mensualidades atadas."
        : "I audit and build accessible websites according to Law 11/2023 and WCAG 2.1 AA. For companies obligated by the European Accessibility Act. No smoke, no tied monthly fees.")

// SEO: Canonical and alternate URLs
// Astro.url.pathname incluye el path actual (ej: /servicios, /en/servicios)
// Para que canonical y alternate funcionen en TODAS las páginas, no solo la home
const currentPath = Astro.url.pathname
const pathWithoutLang =
    lang === "en" ? currentPath.replace(/^\/en/, "") : currentPath

const canonicalUrl =
    lang === "es"
        ? `${siteConfig.url}${pathWithoutLang}`
        : `${siteConfig.url}/en${pathWithoutLang}`

const alternateUrl =
    lang === "es"
        ? `${siteConfig.url}/en${pathWithoutLang}`
        : `${siteConfig.url}${pathWithoutLang}`

const alternateLang = lang === "es" ? "en" : "es"

// OG Image: fallback por idioma si no se pasa una específica
const finalOgImage = ogImage || `${siteConfig.url}/og-default-${lang}.jpg`
const finalOgImageAlt = ogImageAlt || pageTitle
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <link rel="icon" type="image/png" href="/favicon.png" />

        <title>{pageTitle}</title>
        <meta name="description" content={pageDescription} />
        <meta
            name="google-site-verification"
            content="NXHVngJ9aKaRG95Zz8S-JUDRk5cd-4Y0ENlzKwK7GEg"
        />

        <!-- Canonical & hreflang -->
        <link rel="canonical" href={canonicalUrl} />
        <link rel="alternate" hreflang={lang} href={canonicalUrl} />
        <link rel="alternate" hreflang={alternateLang} href={alternateUrl} />
        <link
            rel="alternate"
            hreflang="x-default"
            href={`${siteConfig.url}${pathWithoutLang}`}
        />

        <!-- Open Graph -->
        <meta property="og:type" content="website" />
        <meta property="og:title" content={pageTitle} />
        <meta property="og:description" content={pageDescription} />
        <meta property="og:url" content={canonicalUrl} />
        <meta property="og:site_name" content={siteConfig.name} />
        <meta
            property="og:locale"
            content={lang === "es" ? "es_ES" : "en_US"}
        />
        <meta
            property="og:locale:alternate"
            content={lang === "es" ? "en_US" : "es_ES"}
        />

        <!-- OG Image -->
        <meta property="og:image" content={finalOgImage} />
        <meta property="og:image:secure_url" content={finalOgImage} />
        <meta property="og:image:type" content="image/jpeg" />
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />
        <meta property="og:image:alt" content={finalOgImageAlt} />

        <!-- Twitter -->
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={pageTitle} />
        <meta name="twitter:description" content={pageDescription} />
        <meta name="twitter:image" content={finalOgImage} />
        <meta name="twitter:image:alt" content={finalOgImageAlt} />
    </head>
    <body
        class="bg-bg-primary text-text-primary font-body antialiased overflow-x-hidden"
    >
        <Header lang={lang} />
        <main>
            <slot />
        </main>
        <Footer lang={lang} />
    </body>
</html>
