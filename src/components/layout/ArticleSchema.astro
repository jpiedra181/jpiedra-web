---
// src/components/ArticleSchema.astro
//
// Inyecta JSON-LD Article schema en el <head> de cada post de blog.
// Úsalo dentro del layout de post o de la página [slug].astro,
// preferiblemente DENTRO del <head> (Astro permite slot en head).

interface Props {
    title: string
    description: string
    pubDate: Date
    updatedDate?: Date
    author?: string
    heroImage?: string
    heroImageAlt?: string
    url: string // URL canónica completa del post
    category?: string
    tags?: string[]
}

const {
    title,
    description,
    pubDate,
    updatedDate,
    author = "Javier Piedra",
    heroImage,
    heroImageAlt,
    url,
    category,
    tags = [],
} = Astro.props

const SITE_URL = "https://jpiedra.com" // ajusta si tu dominio definitivo es otro
const LOGO_URL = `${SITE_URL}/web-app-manifest-192x192.png` // opcional, pon la ruta real

// Si heroImage es relativa, la hacemos absoluta
const absoluteImage = heroImage
    ? heroImage.startsWith("http")
        ? heroImage
        : `${SITE_URL}${heroImage.startsWith("/") ? "" : "/"}${heroImage}`
    : undefined

const schema = {
    "@context": "https://schema.org",
    "@type": "Article",
    headline: title,
    description,
    datePublished: pubDate.toISOString(),
    ...(updatedDate && { dateModified: updatedDate.toISOString() }),
    author: {
        "@type": "Person",
        name: author,
        url: SITE_URL,
    },
    publisher: {
        "@type": "Organization",
        name: "jpiedra.com",
        logo: {
            "@type": "ImageObject",
            url: LOGO_URL,
        },
    },
    mainEntityOfPage: {
        "@type": "WebPage",
        "@id": url,
    },
    ...(absoluteImage && {
        image: {
            "@type": "ImageObject",
            url: absoluteImage,
            ...(heroImageAlt && { caption: heroImageAlt }),
        },
    }),
    ...(category && { articleSection: category }),
    ...(tags.length > 0 && { keywords: tags.join(", ") }),
    inLanguage: "es-ES",
}
---

<script type="application/ld+json" set:html={JSON.stringify(schema)} />
