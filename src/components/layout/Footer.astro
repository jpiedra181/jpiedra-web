---
//@ts-nocheck
import type { Lang } from "../../types"
import { useTranslations } from "../../i18n/utils"
import { siteConfig } from "../../config/site"

interface Props {
    lang: Lang
}

const { lang } = Astro.props
const t = useTranslations(lang)
const year = new Date().getFullYear()

const basePath = lang === "es" ? "/" : "/en/"

// Servicios y contenido
const servicesItems = [
    {
        href:
            lang === "es"
                ? "/auditoria-accesibilidad"
                : "/en/accessibility-audit",
        label: t.footer.services.audit,
    },
    {
        href: lang === "es" ? "/blog" : "/en/blog",
        label: t.footer.services.blog,
    },
]

// Páginas legales
const legalItems = [
    {
        href: lang === "es" ? "/aviso-legal" : "/en/legal-notice",
        label: t.footer.legal.legalNotice,
    },
    {
        href: lang === "es" ? "/politica-de-privacidad" : "/en/privacy-policy",
        label: t.footer.legal.privacy,
    },
    {
        href: lang === "es" ? "/politica-de-cookies" : "/en/cookie-policy",
        label: t.footer.legal.cookies,
    },
]
---

<footer class="border-t border-border py-12">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <!-- Top: services + legal + socials -->
        <div
            class="flex flex-col md:flex-row md:items-start md:justify-between gap-10 md:gap-8"
        >
            <!-- Services (left on desktop) -->
            <nav
                aria-label={t.footer.services.label}
                class="flex flex-col gap-3"
            >
                <h3
                    class="text-xs text-text-muted uppercase tracking-wider font-medium"
                >
                    {t.footer.services.label}
                </h3>
                <ul class="flex flex-col gap-2">
                    {
                        servicesItems.map((item) => (
                            <li>
                                <a
                                    href={item.href}
                                    class="text-sm text-text-secondary hover:text-accent transition-colors duration-200"
                                >
                                    {item.label}
                                </a>
                            </li>
                        ))
                    }
                </ul>
            </nav>

            <!-- Legal (right on desktop) -->
            <nav aria-label={t.footer.legal.label} class="flex flex-col gap-3">
                <h3
                    class="text-xs text-text-muted uppercase tracking-wider font-medium"
                >
                    {t.footer.legal.label}
                </h3>
                <ul class="flex flex-col gap-2">
                    {
                        legalItems.map((item) => (
                            <li>
                                <a
                                    href={item.href}
                                    class="text-sm text-text-secondary hover:text-accent transition-colors duration-200"
                                >
                                    {item.label}
                                </a>
                            </li>
                        ))
                    }
                </ul>
            </nav>
        </div>

        <!-- Bottom: socials + copyright -->
        <div
            class="mt-12 pt-8 border-t border-border flex items-center justify-center gap-4"
        >
            <p class="text-xs text-text-muted">
                &copy; {year}
                {siteConfig.name}. {t.footer.rights}
            </p>
        </div>
    </div>
</footer>
