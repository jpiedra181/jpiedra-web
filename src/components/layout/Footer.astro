---
import type { Lang } from "../../types"
import { useTranslations } from "../../i18n/utils"
import { siteConfig } from "../../config/site"

interface Props {
    lang: Lang
}

const { lang } = Astro.props
const t = useTranslations(lang)
const year = new Date().getFullYear()

const navItems = [
    { href: "#about", label: t.nav.about },
    { href: "#approach", label: t.nav.approach },
    { href: "#projects", label: t.nav.projects },
    { href: "#contact", label: t.nav.contact },
]
---

<footer class="border-t border-border py-12">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <div
            class="flex flex-col md:flex-row items-center justify-between gap-8"
        >
            <!-- Nav links -->
            <nav class="flex items-center gap-6">
                {
                    navItems.map((item) => (
                        <a
                            href={item.href}
                            class="text-xs text-text-muted hover:text-text-secondary transition-colors duration-200 uppercase tracking-wider"
                        >
                            {item.label}
                        </a>
                    ))
                }
            </nav>

            <!-- Socials -->
            <div class="flex items-center gap-4">
                <a
                    href={siteConfig.socials.linkedin}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-text-muted hover:text-accent transition-colors duration-200"
                    aria-label="LinkedIn"
                >
                    <svg
                        class="w-5 h-5"
                        fill="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
                        ></path>
                    </svg>
                </a>
            </div>
        </div>

        <!-- Copyright -->
        <div class="mt-8 pt-8 border-t border-border text-center">
            <p class="text-xs text-text-muted">
                &copy; {year}
                {siteConfig.name}. {t.footer.rights}
            </p>
        </div>
    </div>
</footer>
