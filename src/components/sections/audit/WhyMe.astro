---
//@ts-nocheck
import type { Lang } from "../../../types"
import { useTranslations } from "../../../i18n/utils"
import SectionLabel from "../../ui/SectionLabel.astro"

interface Props {
    lang: Lang
}

const { lang } = Astro.props
const t = useTranslations(lang)
---

<section
    id="audit-why-me"
    class="relative py-24 md:py-32 lg:py-40"
    aria-labelledby="audit-why-me-title"
>
    <div class="max-w-7xl mx-auto px-6 lg:px-8 w-full">
        <div class="max-w-3xl">
            <SectionLabel text={t.audit.whyMe.eyebrow} />

            <h2
                id="audit-why-me-title"
                class="audit-why-me-title font-heading text-[clamp(2rem,4vw,3.5rem)] leading-[1.15] text-text-primary mb-8 md:mb-10"
                style="text-wrap: balance;"
            >
                {t.audit.whyMe.title}
            </h2>

            <p
                class="audit-why-me-subtitle text-base md:text-lg text-text-secondary leading-relaxed max-w-2xl mb-12 md:mb-14"
            >
                {t.audit.whyMe.subtitle}
            </p>

            <ul class="flex flex-col gap-10 md:gap-12">
                {
                    t.audit.whyMe.reasons.map((reason) => (
                        <li class="audit-why-me-reason">
                            <h3 class="font-heading text-2xl md:text-3xl text-accent leading-tight mb-4">
                                {reason.title}
                            </h3>
                            <p class="text-base md:text-lg text-text-secondary leading-relaxed max-w-2xl">
                                {reason.description}
                            </p>
                        </li>
                    ))
                }
            </ul>
        </div>
    </div>
</section>
