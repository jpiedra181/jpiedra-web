---
//@ts-nocheck
import type { Lang } from "../../../types"
import { useTranslations } from "../../../i18n/utils"
import SectionLabel from "../../ui/SectionLabel.astro"

interface Props {
    lang: Lang
}

const { lang } = Astro.props
const t = useTranslations(lang)
---

<section
    id="audit-deliverables"
    class="relative py-24 md:py-32 lg:py-40"
    aria-labelledby="audit-deliverables-title"
>
    <div class="max-w-7xl mx-auto px-6 lg:px-8 w-full">
        <div class="max-w-3xl">
            <SectionLabel text={t.audit.deliverables.eyebrow} />

            <h2
                id="audit-deliverables-title"
                class="audit-deliverables-title font-heading text-[clamp(2rem,4vw,3.5rem)] leading-[1.15] text-text-primary mb-8 md:mb-10"
                style="text-wrap: balance;"
            >
                {t.audit.deliverables.title}
            </h2>

            <p
                class="audit-deliverables-subtitle text-base md:text-lg text-text-secondary leading-relaxed max-w-2xl mb-12 md:mb-14"
            >
                {t.audit.deliverables.subtitle}
            </p>

            <ul class="flex flex-col gap-8 md:gap-10">
                {
                    t.audit.deliverables.items.map((item, index) => (
                        <li class="audit-deliverables-item">
                            <div class="flex items-baseline gap-4 mb-3">
                                <span class="font-heading text-xl md:text-2xl text-accent leading-none">
                                    {String(index + 1).padStart(2, "0")}
                                </span>
                                <h3 class="font-heading text-2xl md:text-3xl text-text-primary">
                                    {item.title}
                                </h3>
                            </div>
                            <p class="text-base md:text-lg text-text-secondary leading-relaxed max-w-2xl pl-10 md:pl-12">
                                {item.description}
                            </p>
                        </li>
                    ))
                }
            </ul>
        </div>
    </div>
</section>
