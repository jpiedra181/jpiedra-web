---
//@ts-nocheck
import type { Lang } from "../../../types"
import { useTranslations } from "../../../i18n/utils"
import SectionLabel from "../../ui/SectionLabel.astro"

interface Props {
    lang: Lang
}

const { lang } = Astro.props
const t = useTranslations(lang)
---

<section
    id="audit-hero"
    class="relative py-24 md:py-32 lg:py-40"
    aria-labelledby="audit-hero-title"
>
    <div class="max-w-7xl mx-auto px-6 lg:px-8 w-full">
        <div class="max-w-3xl">
            <SectionLabel text={t.audit.hero.eyebrow} />

            <h1
                id="audit-hero-title"
                class="audit-hero-title font-heading text-[clamp(2.25rem,5vw,4.5rem)] leading-[1.1] text-text-primary mb-8 md:mb-10"
                style="text-wrap: balance;"
            >
                {t.audit.hero.titlePrefix}{" "}
                <span class="text-accent">{t.audit.hero.titleHighlight1}</span>{
                    " "
                }
                {t.audit.hero.titleConnector}{" "}
                <span class="text-accent">{t.audit.hero.titleHighlight2}</span>{
                    t.audit.hero.titleSuffix
                }
            </h1>

            <p
                class="audit-hero-subtitle text-base md:text-lg text-text-secondary leading-relaxed max-w-2xl mb-10 md:mb-12"
            >
                {t.audit.hero.subtitle}
            </p>

            <div class="audit-hero-price mb-8 md:mb-10">
                <p
                    class="font-heading text-[clamp(3.5rem,8vw,6rem)] leading-none text-accent mb-4"
                >
                    <span aria-hidden="true">{t.audit.hero.price}</span>
                    <span class="sr-only">{t.audit.hero.priceAriaLabel}</span>
                </p>
                <p class="text-sm md:text-base text-text-primary font-medium">
                    {t.audit.hero.priceNote}
                </p>
                <p class="text-sm text-text-muted mt-1">
                    {t.audit.hero.priceSubnote}
                </p>
            </div>

            <div class="audit-hero-cta">
                <a
                    href="#solicitar-auditoria"
                    class="inline-block bg-accent text-bg-primary px-8 py-4 rounded-full text-base font-medium hover:bg-accent-hover transition-colors duration-300 focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-white"
                >
                    {t.audit.hero.cta}
                </a>
            </div>
        </div>
    </div>
</section>
