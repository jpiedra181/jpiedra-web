---
//@ts-nocheck
import type { Lang } from "../../../types"
import { useTranslations } from "../../../i18n/utils"
import SectionLabel from "../../ui/SectionLabel.astro"

interface Props {
    lang: Lang
}

const { lang } = Astro.props
const t = useTranslations(lang)
---

<section
    id="audit-after"
    class="relative py-24 md:py-32 lg:py-40"
    aria-labelledby="audit-after-title"
>
    <div class="max-w-7xl mx-auto px-6 lg:px-8 w-full">
        <div class="max-w-3xl">
            <SectionLabel text={t.audit.afterAudit.eyebrow} />

            <h2
                id="audit-after-title"
                class="audit-after-title font-heading text-[clamp(2rem,4vw,3.5rem)] leading-[1.15] text-text-primary mb-8 md:mb-10"
                style="text-wrap: balance;"
            >
                {t.audit.afterAudit.title}
            </h2>

            <p
                class="audit-after-subtitle text-base md:text-lg text-text-secondary leading-relaxed max-w-2xl mb-12 md:mb-14"
            >
                {t.audit.afterAudit.subtitle}
            </p>

            <ul class="flex flex-col gap-10 md:gap-12 mb-12 md:mb-14">
                {
                    t.audit.afterAudit.options.map((option) => (
                        <li class="audit-after-option">
                            <h3 class="font-heading text-2xl md:text-3xl text-text-primary leading-tight mb-4">
                                {option.title}
                                <span class="text-text-muted font-normal text-xl md:text-2xl">
                                    {" "}
                                    {option.optionalTag}
                                </span>
                            </h3>
                            <p class="text-base md:text-lg text-text-secondary leading-relaxed max-w-2xl mb-4">
                                {option.description}
                            </p>
                            <p class="text-sm md:text-base text-text-muted italic leading-relaxed max-w-2xl">
                                {option.priceNote}
                            </p>
                        </li>
                    ))
                }
            </ul>

            <p
                class="audit-after-closing text-base md:text-lg text-text-primary leading-relaxed max-w-2xl"
            >
                {t.audit.afterAudit.closing}
            </p>
        </div>
    </div>
</section>
