---
//@ts-nocheck
import type { Lang } from "../../../types"
import { useTranslations } from "../../../i18n/utils"
import SectionLabel from "../../ui/SectionLabel.astro"

interface Props {
    lang: Lang
}

const { lang } = Astro.props
const t = useTranslations(lang)
---

<section
    id="audit-faq"
    class="relative py-24 md:py-32 lg:py-40"
    aria-labelledby="audit-faq-title"
>
    <div class="max-w-7xl mx-auto px-6 lg:px-8 w-full">
        <div class="max-w-3xl">
            <SectionLabel text={t.audit.faq.eyebrow} />

            <h2
                id="audit-faq-title"
                class="audit-faq-title font-heading text-[clamp(2rem,4vw,3.5rem)] leading-[1.15] text-text-primary mb-12 md:mb-16"
                style="text-wrap: balance;"
            >
                {t.audit.faq.title}
            </h2>

            <div class="flex flex-col">
                {
                    t.audit.faq.items.map((item) => (
                        <details class="audit-faq-item group border-t border-border last:border-b py-6 md:py-8">
                            <summary class="flex items-center justify-between gap-6 cursor-pointer list-none">
                                <h3 class="font-heading text-xl md:text-2xl text-text-primary leading-tight pr-4">
                                    {item.question}
                                </h3>
                                <span
                                    class="font-heading text-2xl md:text-3xl text-accent shrink-0 transition-transform duration-300 group-open:rotate-45"
                                    aria-hidden="true"
                                >
                                    +
                                </span>
                            </summary>
                            <p class="text-base md:text-lg text-text-secondary leading-relaxed max-w-2xl mt-4">
                                {item.answer}
                            </p>
                        </details>
                    ))
                }
            </div>
        </div>
    </div>
</section>
