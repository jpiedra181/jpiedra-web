---
//@ts-nocheck
import type { Lang } from "../../../types"
import { useTranslations } from "../../../i18n/utils"
import SectionLabel from "../../ui/SectionLabel.astro"

interface Props {
    lang: Lang
}

const { lang } = Astro.props
const t = useTranslations(lang)

const privacyHref =
    lang === "en" ? "/en/privacy-policy" : "/politica-de-privacidad"
---

<section
    id="solicitar-auditoria"
    class="relative py-24 md:py-32 lg:py-40"
    aria-labelledby="audit-request-title"
>
    <div class="relative max-w-7xl mx-auto px-6 lg:px-8 w-full">
        <!-- Eyebrow -->
        <div class="max-w-3xl">
            <SectionLabel text={t.audit.requestForm.eyebrow} />

            <!-- Title -->
            <h2
                id="audit-request-title"
                class="font-heading text-[clamp(2rem,4vw,3.5rem)] leading-[1.15] text-text-primary mt-6 md:mt-8 max-w-[24ch]"
                style="text-wrap: balance;"
            >
                {t.audit.requestForm.title}
            </h2>

            <!-- Subtitle -->
            <p
                class="font-body text-[clamp(1rem,1.4vw,1.25rem)] leading-relaxed text-text-primary mt-6 md:mt-8 max-w-[45rem]"
            >
                {t.audit.requestForm.subtitle}
            </p>
        </div>

        <!-- Form -->
        <form
            id="audit-request-form"
            class="mt-12 md:mt-16 lg:mt-20 w-full max-w-[600px] flex flex-col gap-8 md:gap-10"
            novalidate
            data-lang={lang}
            data-success={t.audit.requestForm.success}
            data-error={t.audit.requestForm.error}
            data-sending={t.audit.requestForm.sending}
            data-submit={t.audit.requestForm.cta}
            data-error-required={t.audit.requestForm.errors.required}
            data-error-email={t.audit.requestForm.errors.email}
            data-error-url={t.audit.requestForm.errors.url}
            data-error-select={t.audit.requestForm.errors.select}
            data-error-privacy={t.audit.requestForm.errors.privacy}
        >
            <!-- Name -->
            <div class="flex flex-col gap-3">
                <label
                    for="audit-name"
                    class="font-body text-sm font-medium text-text-primary"
                >
                    <span>{t.audit.requestForm.fields.name.label}</span>
                </label>
                <input
                    type="text"
                    id="audit-name"
                    name="name"
                    required
                    aria-required="true"
                    aria-describedby="audit-name-error"
                    autocomplete="name"
                    placeholder={t.audit.requestForm.fields.name.placeholder}
                    class="w-full bg-transparent border-0 border-b-2 border-border px-0 py-3 text-base font-body text-text-primary placeholder:text-text-muted focus:outline-none focus-visible:border-accent transition-colors duration-200 aria-[invalid=true]:border-red-400"
                />
                <p
                    id="audit-name-error"
                    class="audit-error text-sm text-red-400 font-body"
                    hidden
                >
                </p>
            </div>

            <!-- Email -->
            <div class="flex flex-col gap-3">
                <label
                    for="audit-email"
                    class="font-body text-sm font-medium text-text-primary"
                >
                    <span>{t.audit.requestForm.fields.email.label}</span>
                </label>
                <input
                    type="email"
                    id="audit-email"
                    name="email"
                    required
                    aria-required="true"
                    aria-describedby="audit-email-error"
                    autocomplete="email"
                    placeholder={t.audit.requestForm.fields.email.placeholder}
                    class="w-full bg-transparent border-0 border-b-2 border-border px-0 py-3 text-base font-body text-text-primary placeholder:text-text-muted focus:outline-none focus-visible:border-accent transition-colors duration-200 aria-[invalid=true]:border-red-400"
                />
                <p
                    id="audit-email-error"
                    class="audit-error text-sm text-red-400 font-body"
                    hidden
                >
                </p>
            </div>

            <!-- Company -->
            <div class="flex flex-col gap-3">
                <label
                    for="audit-company"
                    class="font-body text-sm font-medium text-text-primary"
                >
                    <span>{t.audit.requestForm.fields.company.label}</span>
                </label>
                <input
                    type="text"
                    id="audit-company"
                    name="company"
                    required
                    aria-required="true"
                    aria-describedby="audit-company-error"
                    autocomplete="organization"
                    placeholder={t.audit.requestForm.fields.company.placeholder}
                    class="w-full bg-transparent border-0 border-b-2 border-border px-0 py-3 text-base font-body text-text-primary placeholder:text-text-muted focus:outline-none focus-visible:border-accent transition-colors duration-200 aria-[invalid=true]:border-red-400"
                />
                <p
                    id="audit-company-error"
                    class="audit-error text-sm text-red-400 font-body"
                    hidden
                >
                </p>
            </div>

            <!-- URL -->
            <div class="flex flex-col gap-3">
                <label
                    for="audit-url"
                    class="font-body text-sm font-medium text-text-primary"
                >
                    <span>{t.audit.requestForm.fields.url.label}</span>
                </label>
                <input
                    type="url"
                    id="audit-url"
                    name="url"
                    required
                    aria-required="true"
                    aria-describedby="audit-url-error"
                    autocomplete="url"
                    inputmode="url"
                    placeholder={t.audit.requestForm.fields.url.placeholder}
                    class="w-full bg-transparent border-0 border-b-2 border-border px-0 py-3 text-base font-body text-text-primary placeholder:text-text-muted focus:outline-none focus-visible:border-accent transition-colors duration-200 aria-[invalid=true]:border-red-400"
                />
                <p
                    id="audit-url-error"
                    class="audit-error text-sm text-red-400 font-body"
                    hidden
                >
                </p>
            </div>

            <!-- Sector -->
            <div class="flex flex-col gap-3">
                <label
                    for="audit-sector"
                    class="font-body text-sm font-medium text-text-primary"
                >
                    <span>{t.audit.requestForm.fields.sector.label}</span>
                </label>
                <select
                    id="audit-sector"
                    name="sector"
                    required
                    aria-required="true"
                    aria-describedby="audit-sector-error"
                    class="w-full bg-transparent border-0 border-b-2 border-border px-0 py-3 text-base font-body text-text-primary focus:outline-none focus-visible:border-accent transition-colors duration-200 aria-[invalid=true]:border-red-400"
                >
                    <option value="" disabled selected
                        >{t.audit.requestForm.fields.sector.placeholder}</option
                    >
                    {
                        t.audit.requestForm.fields.sector.options.map((opt) => (
                            <option
                                value={opt.value}
                                class="bg-bg-primary text-text-primary"
                            >
                                {opt.label}
                            </option>
                        ))
                    }
                </select>
                <p
                    id="audit-sector-error"
                    class="audit-error text-sm text-red-400 font-body"
                    hidden
                >
                </p>
            </div>

            <!-- Size -->
            <div class="flex flex-col gap-3">
                <label
                    for="audit-size"
                    class="font-body text-sm font-medium text-text-primary"
                >
                    <span>{t.audit.requestForm.fields.size.label}</span>
                </label>
                <select
                    id="audit-size"
                    name="size"
                    required
                    aria-required="true"
                    aria-describedby="audit-size-error"
                    class="w-full bg-transparent border-0 border-b-2 border-border px-0 py-3 text-base font-body text-text-primary focus:outline-none focus-visible:border-accent transition-colors duration-200 aria-[invalid=true]:border-red-400"
                >
                    <option value="" disabled selected
                        >{t.audit.requestForm.fields.size.placeholder}</option
                    >
                    {
                        t.audit.requestForm.fields.size.options.map((opt) => (
                            <option
                                value={opt.value}
                                class="bg-bg-primary text-text-primary"
                            >
                                {opt.label}
                            </option>
                        ))
                    }
                </select>
                <p
                    id="audit-size-error"
                    class="audit-error text-sm text-red-400 font-body"
                    hidden
                >
                </p>
            </div>

            <!-- Timing -->
            <div class="flex flex-col gap-3">
                <label
                    for="audit-timing"
                    class="font-body text-sm font-medium text-text-primary"
                >
                    <span>{t.audit.requestForm.fields.timing.label}</span>
                </label>
                <select
                    id="audit-timing"
                    name="timing"
                    required
                    aria-required="true"
                    aria-describedby="audit-timing-error"
                    class="w-full bg-transparent border-0 border-b-2 border-border px-0 py-3 text-base font-body text-text-primary focus:outline-none focus-visible:border-accent transition-colors duration-200 aria-[invalid=true]:border-red-400"
                >
                    <option value="" disabled selected
                        >{t.audit.requestForm.fields.timing.placeholder}</option
                    >
                    {
                        t.audit.requestForm.fields.timing.options.map((opt) => (
                            <option
                                value={opt.value}
                                class="bg-bg-primary text-text-primary"
                            >
                                {opt.label}
                            </option>
                        ))
                    }
                </select>
                <p
                    id="audit-timing-error"
                    class="audit-error text-sm text-red-400 font-body"
                    hidden
                >
                </p>
            </div>

            <!-- Comments (optional) -->
            <div class="flex flex-col gap-3">
                <label
                    for="audit-comments"
                    class="font-body text-sm font-medium text-text-primary"
                >
                    <span>{t.audit.requestForm.fields.comments.label}</span>
                    <span class="text-text-muted text-xs font-normal ml-2">
                        {t.audit.requestForm.fields.comments.optional}
                    </span>
                </label>
                <textarea
                    id="audit-comments"
                    name="comments"
                    aria-required="false"
                    rows={4}
                    placeholder={t.audit.requestForm.fields.comments
                        .placeholder}
                    class="w-full bg-transparent border-0 border-b-2 border-border px-0 py-3 text-base font-body text-text-primary placeholder:text-text-muted focus:outline-none focus-visible:border-accent transition-colors duration-200 resize-y min-h-[120px]"
                ></textarea>
            </div>

            <!-- Honeypot (anti-spam, invisible to humans, present for bots) -->
            <div
                aria-hidden="true"
                class="absolute -left-[9999px] w-px h-px overflow-hidden"
            >
                <label for="audit-website-trap">Website</label>
                <input
                    type="text"
                    id="audit-website-trap"
                    name="website_trap"
                    tabindex="-1"
                    autocomplete="off"
                />
            </div>

            <!-- Submit + privacy + availability -->
            <div class="flex flex-col gap-3 pt-2">
                <!-- Privacy consent checkbox -->
                <div class="flex flex-col gap-2 mb-4">
                    <label
                        for="audit-privacy"
                        class="flex items-start gap-3 cursor-pointer text-sm font-body text-text-primary"
                    >
                        <input
                            type="checkbox"
                            id="audit-privacy"
                            name="privacy"
                            required
                            aria-required="true"
                            aria-describedby="audit-privacy-error"
                            class="w-4 h-4 accent-accent cursor-pointer flex-shrink-0"
                        />
                        <span class="text-text-primary">
                            {t.audit.requestForm.privacyConsent}<a
                                href={privacyHref}
                                target="_blank"
                                class="underline underline-offset-2 hover:text-accent-hover focus:outline-none focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent rounded-sm"
                                >{t.audit.requestForm.privacyConsentLink}</a
                            >{t.audit.requestForm.privacyConsentEnd}
                        </span>
                    </label>
                    <p
                        id="audit-privacy-error"
                        class="audit-error text-sm text-red-400 font-body ml-7"
                        hidden
                    >
                    </p>
                </div>
                <button
                    type="submit"
                    id="audit-submit"
                    class="cursor-pointer self-start inline-flex items-center gap-2 font-body font-medium text-sm tracking-wide transition-all duration-300 rounded-full bg-accent text-bg-primary hover:bg-accent-hover px-7 py-3.5 hover:shadow-lg hover:shadow-accent/20 disabled:opacity-50 disabled:cursor-not-allowed focus:outline-none focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent min-h-[44px] mb-1"
                >
                    <span id="audit-submit-text">{t.audit.requestForm.cta}</span
                    >
                </button>
            </div>
        </form>

        <div class="mt-10 md:mt-12 flex flex-col gap-5 max-w-[600px]">
            <p
                id="audit-feedback"
                role="status"
                aria-live="polite"
                class="text-sm font-body empty:hidden"
            >
            </p>

            <p class="text-sm text-text-muted font-body">
                {t.audit.requestForm.responseTime}
            </p>

            <div class="flex items-center gap-3">
                <span class="relative flex h-2.5 w-2.5" aria-hidden="true">
                    <span
                        class="motion-safe:animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"
                    ></span>
                    <span
                        class="relative inline-flex rounded-full h-2.5 w-2.5 bg-green-500"
                    ></span>
                </span>
                <span class="text-sm text-text-secondary font-body">
                    {t.contact.available}
                </span>
            </div>
        </div>
    </div>
</section>

<script>
    type InputFieldId =
        | "audit-name"
        | "audit-email"
        | "audit-company"
        | "audit-url"
    type SelectFieldId = "audit-sector" | "audit-size" | "audit-timing"
    type FieldId = InputFieldId | SelectFieldId

    const INPUT_FIELDS: InputFieldId[] = [
        "audit-name",
        "audit-email",
        "audit-company",
        "audit-url",
    ]
    const SELECT_FIELDS: SelectFieldId[] = [
        "audit-sector",
        "audit-size",
        "audit-timing",
    ]
    const ALL_FIELDS: FieldId[] = [...INPUT_FIELDS, ...SELECT_FIELDS]

    const form = document.getElementById(
        "audit-request-form",
    ) as HTMLFormElement
    const submitBtn = document.getElementById(
        "audit-submit",
    ) as HTMLButtonElement
    const submitText = document.getElementById("audit-submit-text")!
    const feedback = document.getElementById("audit-feedback")!

    const messages = {
        success: form.dataset.success!,
        error: form.dataset.error!,
        sending: form.dataset.sending!,
        submit: form.dataset.submit!,
        required: form.dataset.errorRequired!,
        email: form.dataset.errorEmail!,
        url: form.dataset.errorUrl!,
        select: form.dataset.errorSelect!,
        privacy: form.dataset.errorPrivacy!,
    }

    function getField(id: FieldId) {
        return document.getElementById(id) as
            | HTMLInputElement
            | HTMLSelectElement
    }

    function getError(id: FieldId) {
        return document.getElementById(`${id}-error`)!
    }

    function setError(id: FieldId, message: string | null) {
        const field = getField(id)
        const errorEl = getError(id)
        if (message) {
            field.setAttribute("aria-invalid", "true")
            errorEl.textContent = message
            errorEl.hidden = false
        } else {
            field.setAttribute("aria-invalid", "false")
            errorEl.textContent = ""
            errorEl.hidden = true
        }
    }

    function clearAllErrors() {
        ALL_FIELDS.forEach((id) => setError(id, null))
    }

    function validate(): { valid: boolean; firstInvalid: FieldId | null } {
        let firstInvalid: FieldId | null = null

        // Text inputs
        const name = (getField("audit-name") as HTMLInputElement).value.trim()
        if (!name) {
            setError("audit-name", messages.required)
            firstInvalid ??= "audit-name"
        } else setError("audit-name", null)

        const emailField = getField("audit-email") as HTMLInputElement
        const email = emailField.value.trim()
        if (!email) {
            setError("audit-email", messages.required)
            firstInvalid ??= "audit-email"
        } else if (!emailField.checkValidity()) {
            setError("audit-email", messages.email)
            firstInvalid ??= "audit-email"
        } else setError("audit-email", null)

        const company = (
            getField("audit-company") as HTMLInputElement
        ).value.trim()
        if (!company) {
            setError("audit-company", messages.required)
            firstInvalid ??= "audit-company"
        } else setError("audit-company", null)

        const urlField = getField("audit-url") as HTMLInputElement
        const url = urlField.value.trim()
        if (!url) {
            setError("audit-url", messages.required)
            firstInvalid ??= "audit-url"
        } else if (!urlField.checkValidity()) {
            setError("audit-url", messages.url)
            firstInvalid ??= "audit-url"
        } else setError("audit-url", null)

        // Selects
        SELECT_FIELDS.forEach((id) => {
            const value = (getField(id) as HTMLSelectElement).value
            if (!value) {
                setError(id, messages.select)
                firstInvalid ??= id
            } else setError(id, null)
        })

        // Privacy
        const privacyField = document.getElementById(
            "audit-privacy",
        ) as HTMLInputElement
        const privacyError = document.getElementById("audit-privacy-error")!
        if (!privacyField.checked) {
            privacyField.setAttribute("aria-invalid", "true")
            privacyError.textContent = messages.privacy
            privacyError.hidden = false
            if (!firstInvalid) {
                privacyField.focus()
            }
            return { valid: false, firstInvalid }
        } else {
            privacyField.setAttribute("aria-invalid", "false")
            privacyError.textContent = ""
            privacyError.hidden = true
        }

        return { valid: firstInvalid === null, firstInvalid }
    }

    // Clear field error as the user fixes it
    INPUT_FIELDS.forEach((id) => {
        getField(id).addEventListener("input", () => {
            if (getField(id).getAttribute("aria-invalid") === "true") {
                setError(id, null)
            }
        })
    })
    SELECT_FIELDS.forEach((id) => {
        getField(id).addEventListener("change", () => {
            if (getField(id).getAttribute("aria-invalid") === "true") {
                setError(id, null)
            }
        })
    })

    // Clear privacy error when checkbox is checked
    document.getElementById("audit-privacy")!.addEventListener("change", () => {
        const privacyField = document.getElementById(
            "audit-privacy",
        ) as HTMLInputElement
        const privacyError = document.getElementById("audit-privacy-error")!
        if (privacyField.checked) {
            privacyField.setAttribute("aria-invalid", "false")
            privacyError.textContent = ""
            privacyError.hidden = true
        }
    })

    function setFeedback(text: string, tone: "neutral" | "success" | "error") {
        feedback.textContent = text
        feedback.classList.remove(
            "text-red-400",
            "text-green-400",
            "text-text-secondary",
        )
        if (tone === "success") feedback.classList.add("text-green-400")
        else if (tone === "error") feedback.classList.add("text-red-400")
        else feedback.classList.add("text-text-secondary")
    }

    form.addEventListener("submit", async (e) => {
        e.preventDefault()

        const { valid, firstInvalid } = validate()
        if (!valid) {
            if (firstInvalid) getField(firstInvalid).focus()
            return
        }

        // Honeypot — if filled, silently bail
        const honeypot = document.getElementById(
            "audit-website-trap",
        ) as HTMLInputElement
        if (honeypot && honeypot.value.trim() !== "") {
            setFeedback(messages.success, "success")
            form.reset()
            return
        }

        submitBtn.disabled = true
        submitText.textContent = messages.sending
        setFeedback(messages.sending, "neutral")

        try {
            const data = {
                name: (getField("audit-name") as HTMLInputElement).value.trim(),
                email: (
                    getField("audit-email") as HTMLInputElement
                ).value.trim(),
                company: (
                    getField("audit-company") as HTMLInputElement
                ).value.trim(),
                url: (getField("audit-url") as HTMLInputElement).value.trim(),
                sector: (getField("audit-sector") as HTMLSelectElement).value,
                size: (getField("audit-size") as HTMLSelectElement).value,
                timing: (getField("audit-timing") as HTMLSelectElement).value,
                comments: (
                    document.getElementById(
                        "audit-comments",
                    ) as HTMLTextAreaElement
                ).value.trim(),
                lang: form.dataset.lang,
                privacy_accepted: true,
                privacy_accepted_at: new Date().toISOString(),
            }

            const endpoint = "https://n8n.zerosugar.studio/webhook/landing"

            const response = await fetch(endpoint, {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify(data),
            })

            if (!response.ok)
                throw new Error(`Server error: ${response.status}`)

            setFeedback(messages.success, "success")
            form.reset()
            clearAllErrors()
        } catch (err) {
            console.error("Form error:", err)
            setFeedback(messages.error, "error")
        } finally {
            submitBtn.disabled = false
            submitText.textContent = messages.submit
        }
    })
</script>
