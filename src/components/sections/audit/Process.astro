---
//@ts-nocheck
import type { Lang } from "../../../types"
import { useTranslations } from "../../../i18n/utils"
import SectionLabel from "../../ui/SectionLabel.astro"

interface Props {
    lang: Lang
}

const { lang } = Astro.props
const t = useTranslations(lang)
---

<section
    id="audit-process"
    class="relative py-24 md:py-32 lg:py-40"
    aria-labelledby="audit-process-title"
>
    <div class="max-w-7xl mx-auto px-6 lg:px-8 w-full">
        <div class="max-w-3xl mb-16 md:mb-20">
            <SectionLabel text={t.audit.process.eyebrow} />

            <h2
                id="audit-process-title"
                class="audit-process-title font-heading text-[clamp(2rem,4vw,3.5rem)] leading-[1.15] text-text-primary mb-8 md:mb-10"
                style="text-wrap: balance;"
            >
                {t.audit.process.title}
            </h2>

            <p
                class="audit-process-subtitle text-base md:text-lg text-text-secondary leading-relaxed max-w-2xl"
            >
                {t.audit.process.subtitle}
            </p>
        </div>

        <ol class="flex flex-col gap-16 md:gap-20">
            {t.audit.process.steps.map((step, index) => (
                <li class="audit-process-step grid grid-cols-1 md:grid-cols-12 gap-6 md:gap-10">
                    <!-- Columna izquierda: número + duración -->
                    <div class="md:col-span-3 lg:col-span-4">
                        <p class="font-heading text-5xl md:text-6xl lg:text-7xl text-accent leading-none mb-3">
                            {String(index + 1).padStart(2, "0")}
                        </p>
                        <p class="text-sm md:text-base text-text-muted uppercase tracking-[0.15em]">
                            {step.duration}
                        </p>
                    </div>

                    <!-- Columna derecha: contenido -->
                    <div class="md:col-span-9 lg:col-span-8">
                        <h3 class="font-heading text-2xl md:text-3xl text-text-primary leading-tight mb-4">
                            {step.title}
                        </h3>
                        <p class="text-base md:text-lg text-text-secondary leading-relaxed max-w-2xl mb-4">
                            {step.description}
                        </p>
                        <p class="text-sm md:text-base text-text-muted italic leading-relaxed max-w-2xl">
                            {step.clientInput}
                        </p>
                    </div>
                </li>
            ))}
        </ol>
    </div>
</section>