---
//@ts-nocheck
import type { Lang } from "../../../types"
import { useTranslations } from "../../../i18n/utils"
import SectionLabel from "../../ui/SectionLabel.astro"

interface Props {
    lang: Lang
}

const { lang } = Astro.props
const t = useTranslations(lang)
---

<section
    id="audit-who-must-comply"
    class="relative py-24 md:py-32 lg:py-40"
    aria-labelledby="audit-who-must-comply-title"
>
    <div class="max-w-7xl mx-auto px-6 lg:px-8 w-full">
        <div class="max-w-3xl">
            <SectionLabel text={t.audit.whoMustComply.eyebrow} />

            <h2
                id="audit-who-must-comply-title"
                class="audit-who-must-comply-title font-heading text-[clamp(2rem,4vw,3.5rem)] leading-[1.15] text-text-primary mb-8 md:mb-10"
                style="text-wrap: balance;"
            >
                {t.audit.whoMustComply.title}
            </h2>

            <p
                class="audit-who-must-comply-subtitle text-base md:text-lg text-text-secondary leading-relaxed max-w-2xl mb-12 md:mb-14"
            >
                {t.audit.whoMustComply.subtitle}
            </p>

            <ul class="flex flex-col gap-12 md:gap-16 mb-12 md:mb-14">
                {
                    t.audit.whoMustComply.groups.map((group) => (
                        <li class="audit-who-must-comply-group">
                            <p class="font-heading text-xs md:text-sm uppercase tracking-[0.2em] text-accent mb-4">
                                {group.tag}
                            </p>
                            <h3 class="font-heading text-2xl md:text-3xl text-text-primary leading-tight mb-4">
                                {group.headline}
                            </h3>
                            <p class="text-base md:text-lg text-text-secondary leading-relaxed max-w-2xl mb-4">
                                {group.body}
                            </p>
                            {group.note && (
                                <p class="text-sm md:text-base text-text-muted italic leading-relaxed max-w-2xl">
                                    {group.note}
                                </p>
                            )}
                        </li>
                    ))
                }
            </ul>

            <p
                class="audit-who-must-comply-closing text-base md:text-lg text-text-primary leading-relaxed max-w-2xl"
            >
                {t.audit.whoMustComply.closing}
            </p>
        </div>
    </div>
</section>
