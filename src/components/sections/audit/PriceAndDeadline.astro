---
//@ts-nocheck
import type { Lang } from "../../../types"
import { useTranslations } from "../../../i18n/utils"
import SectionLabel from "../../ui/SectionLabel.astro"

interface Props {
    lang: Lang
}

const { lang } = Astro.props
const t = useTranslations(lang)
---

<section
    id="audit-price"
    class="relative py-24 md:py-32 lg:py-40"
    aria-labelledby="audit-price-title"
>
    <div class="max-w-7xl mx-auto px-6 lg:px-8 w-full">
        <div class="max-w-4xl mx-auto text-center">
            <div class="mb-12 md:mb-16">
                <p
                    class="font-heading text-xs md:text-sm uppercase tracking-[0.2em] text-accent"
                >
                    {t.audit.priceAndDeadline.eyebrow}
                </p>
            </div>

            <h2 id="audit-price-title" class="sr-only">
                {t.audit.priceAndDeadline.srTitle}
            </h2>

            <div
                class="grid grid-cols-1 md:grid-cols-3 gap-12 md:gap-8 mb-16 md:mb-20"
            >
                {
                    t.audit.priceAndDeadline.pillars.map((pillar) => (
                        <div class="audit-price-pillar">
                            <p class="font-heading text-5xl md:text-6xl lg:text-7xl text-accent leading-none mb-4">
                                {pillar.value}
                            </p>
                            <p class="text-base md:text-lg text-text-secondary leading-relaxed">
                                {pillar.label}
                            </p>
                        </div>
                    ))
                }
            </div>

            <p
                class="audit-price-closing font-heading text-2xl md:text-3xl lg:text-4xl text-text-primary leading-tight max-w-2xl mx-auto"
            >
                {t.audit.priceAndDeadline.closing}
            </p>
        </div>
    </div>
</section>
