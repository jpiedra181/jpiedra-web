---
//@ts-nocheck
import type { Lang } from "../../types"
import { useTranslations } from "../../i18n/utils"
import SectionLabel from "../ui/SectionLabel.astro"
import avatar from "../../assets/images/avatar.png"

interface Props {
    lang: Lang
}

const { lang } = Astro.props
const t = useTranslations(lang)
---

<section id="about" class="relative py-24 md:py-32 lg:py-40">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
            <!-- Text -->
            <div class="order-1 lg:order-1">
                <SectionLabel text={t.about.label} />
                <h2
                    class="about-title font-heading text-[clamp(2rem,4vw,3.5rem)] leading-[1.15] text-text-primary mb-6 md:mb-8"
                >
                    {t.about.title}
                </h2>
                <div class="flex flex-col gap-5 md:gap-6">
                    <p
                        class="about-text text-base md:text-lg text-text-secondary leading-relaxed"
                    >
                        {t.about.text_1}
                    </p>
                    <p
                        class="about-text text-base md:text-lg text-text-secondary leading-relaxed"
                    >
                        {t.about.text_2}
                    </p>
                    <p
                        class="about-text text-base md:text-lg text-text-secondary leading-relaxed"
                    >
                        {t.about.text_3}
                    </p>
                </div>
                <a
                    href="/auditoria-accesibilidad"
                    class="inline-block mt-8 text-white underline underline-offset-2 font-medium hover:text-accent transition-colors"
                >
                    {t.about.cta}
                </a>
            </div>

            <!-- Image (hidden until populated to avoid empty space on mobile) -->
            <!-- <div class="about-image relative order-2 lg:order-2">
                <div class="aspect-[4/5] rounded-2xl overflow-hidden relative">
                    <img
                        src={avatar.src}
                        alt="Workspace"
                        class="w-full h-full object-cover"
                        loading="lazy"
                    />
                </div>
            </div> -->
        </div>
    </div>
</section>
