---
//@ts-nocheck
import type { Lang } from "../../types"
import { useTranslations } from "../../i18n/utils"
import SectionLabel from "../ui/SectionLabel.astro"
import avatar from "../../assets/images/avatar.png"

interface Props {
    lang: Lang
}

const { lang } = Astro.props
const t = useTranslations(lang)
---

<section id="about" class="py-32 relative">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <div class="grid lg:grid-cols-2 gap-16 items-center">
            <!-- Image -->
            <div class="about-image relative order-2 lg:order-1">
                <div class="aspect-[4/5] rounded-2xl overflow-hidden relative">
                    <img
                        src={avatar.src}
                        alt="Workspace"
                        class="w-full h-full object-cover"
                        loading="lazy"
                    />
                    <div
                        class="absolute inset-0 bg-gradient-to-t from-bg-primary/60 to-transparent"
                    >
                    </div>
                </div>
                <!-- Decorative accent -->
                <div
                    class="absolute -bottom-4 -right-4 w-24 h-24 border border-accent-line rounded-2xl -z-10"
                >
                </div>
            </div>

            <!-- Text -->
            <div class="order-1 lg:order-2">
                <SectionLabel text={t.about.label} />
                <h2
                    class="about-title font-heading text-[clamp(2rem,4vw,3.5rem)] leading-[1.15] text-text-primary mb-8"
                >
                    {t.about.title}
                </h2>
                <p
                    class="about-text text-lg text-text-secondary leading-relaxed mb-6"
                >
                    {t.about.text_1}
                </p>
                <p
                    class="about-text text-lg text-text-secondary leading-relaxed mb-6"
                >
                    {t.about.text_2}
                </p>
                <p
                    class="about-text text-lg text-text-secondary leading-relaxed"
                >
                    {t.about.text_3}
                </p>
            </div>
        </div>
    </div>
</section>
