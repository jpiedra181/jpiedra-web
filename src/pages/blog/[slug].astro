---
//@ts-nocheck
import { getCollection, render, type CollectionEntry } from "astro:content"
import BaseLayout from "../../components/layout/BaseLayout.astro"
import ArticleSchema from "../../components/layout/ArticleSchema.astro"

export async function getStaticPaths() {
    const posts = await getCollection("blog")
    return posts.map((post) => ({
        params: { slug: post.id },
        props: { post },
    }))
}

interface Props {
    post: CollectionEntry<"blog">
}

const { post } = Astro.props
const { Content } = await render(post)
const lang = "es" as const

// URL canónica del post
const canonicalURL = new URL(`/blog/${post.id}`, Astro.site).toString()
---

<BaseLayout
    lang={lang}
    title={`${post.data.title} — Javier Piedra`}
    description={post.data.description}
>
    <ArticleSchema
        title={post.data.title}
        description={post.data.description}
        pubDate={post.data.pubDate}
        updatedDate={post.data.updatedDate}
        heroImage={post.data.heroImage}
        heroImageAlt={post.data.heroImageAlt}
        url={canonicalURL}
        tags={post.data.tags}
        category={post.data.category}
    />
    <article class="relative py-24 md:py-32 lg:py-40">
        <div class="max-w-7xl mx-auto px-6 lg:px-8 w-full">
            <header class="max-w-3xl mb-16 md:mb-20">
                <a
                    href="/blog"
                    class="inline-block text-sm text-text-muted hover:text-accent transition-colors mb-8"
                >
                    ← Volver al blog
                </a>

                <time
                    datetime={post.data.pubDate.toISOString()}
                    class="block text-sm text-text-muted mb-4"
                >
                    {
                        post.data.pubDate.toLocaleDateString("es-ES", {
                            year: "numeric",
                            month: "long",
                            day: "numeric",
                        })
                    }
                </time>

                <h1
                    class="font-heading text-[clamp(2.25rem,5vw,4.5rem)] leading-[1.1] text-text-primary mb-6"
                    style="text-wrap: balance;"
                >
                    {post.data.title}
                </h1>

                <p
                    class="text-lg md:text-xl text-text-secondary leading-relaxed"
                >
                    {post.data.description}
                </p>
                {
                    post.data.heroImage && (
                        <figure class="mt-12">
                            <img
                                src={post.data.heroImage}
                                alt={post.data.heroImageAlt ?? ""}
                                loading="eager"
                                decoding="async"
                                class="w-full rounded-lg"
                            />
                        </figure>
                    )
                }
            </header>

            <div class="blog-prose max-w-3xl">
                <Content />
            </div>
        </div>
    </article>
</BaseLayout>

<style is:global>
    .blog-prose {
        font-size: 1.0625rem;
        line-height: 1.75;
        color: var(--color-text-secondary);
    }

    .blog-prose > * + * {
        margin-top: 1.5em;
    }

    .blog-prose h2 {
        font-family: var(--font-heading);
        font-size: clamp(1.75rem, 3vw, 2.5rem);
        line-height: 1.2;
        color: var(--color-text-primary);
        margin-top: 2.5em;
        margin-bottom: 0.5em;
        text-wrap: balance;
    }

    .blog-prose h3 {
        font-family: var(--font-heading);
        font-size: clamp(1.375rem, 2.5vw, 1.75rem);
        line-height: 1.3;
        color: var(--color-text-primary);
        margin-top: 2em;
        margin-bottom: 0.5em;
    }

    .blog-prose p {
        margin-top: 1.25em;
        margin-bottom: 1.25em;
    }

    .blog-prose a {
        color: var(--color-accent);
        text-decoration: underline;
        text-underline-offset: 3px;
        text-decoration-thickness: 1px;
        transition: color 0.2s;
    }

    .blog-prose a:hover {
        color: var(--color-accent-hover);
    }

    .blog-prose strong {
        color: var(--color-text-primary);
        font-weight: 600;
    }

    .blog-prose ul,
    .blog-prose ol {
        padding-left: 1.5em;
        margin-top: 1.25em;
        margin-bottom: 1.25em;
    }

    .blog-prose ul {
        list-style: disc;
    }

    .blog-prose ol {
        list-style: decimal;
    }

    .blog-prose li {
        margin-top: 0.5em;
        margin-bottom: 0.5em;
    }

    .blog-prose blockquote {
        border-left: 3px solid var(--color-accent);
        padding-left: 1.5em;
        margin-top: 2em;
        margin-bottom: 2em;
        font-style: italic;
        color: var(--color-text-primary);
    }

    .blog-prose code {
        background-color: var(--color-bg-elevated);
        padding: 0.15em 0.4em;
        border-radius: 4px;
        font-size: 0.9em;
        color: var(--color-accent);
    }

    .blog-prose pre {
        background-color: var(--color-bg-elevated);
        padding: 1.25em;
        border-radius: 8px;
        overflow-x: auto;
        margin-top: 1.5em;
        margin-bottom: 1.5em;
    }

    .blog-prose pre code {
        background-color: transparent;
        padding: 0;
        color: var(--color-text-secondary);
    }

    .blog-prose hr {
        border: 0;
        border-top: 1px solid var(--color-border);
        margin-top: 3em;
        margin-bottom: 3em;
    }

    .blog-prose img {
        border-radius: 8px;
        margin-top: 2em;
        margin-bottom: 2em;
    }
</style>
