---
//@ts-nocheck
import BaseLayout from "../components/layout/BaseLayout.astro"
import { useTranslations } from "../i18n/utils"

// Static 404 is built once. Render in Spanish (primary lang); a tiny inline
// script swaps to English when the URL starts with /en/.
const lang = "es" as const
const es = useTranslations("es")
const en = useTranslations("en")

const t = es.notFound
---

<BaseLayout lang={lang} title={t.metaTitle} description={t.metaDescription}>
    <section
        id="not-found"
        aria-labelledby="not-found-title"
        class="relative min-h-screen flex items-center overflow-hidden"
    >
        <!-- Blueprint grid background (same vibe as Hero) -->
        <div
            aria-hidden="true"
            class="absolute inset-0 opacity-[0.03]"
            style="background-image: linear-gradient(rgba(232,200,114,0.3) 1px, transparent 1px), linear-gradient(90deg, rgba(232,200,114,0.3) 1px, transparent 1px); background-size: 60px 60px;"
        >
        </div>

        <!-- Soft golden glow -->
        <div
            aria-hidden="true"
            class="absolute top-1/3 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[40rem] h-[40rem] max-w-[80vw] max-h-[80vw] rounded-full blur-[120px] opacity-[0.08]"
            style="background: radial-gradient(circle, #E8C872 0%, transparent 70%);"
        >
        </div>

        <div
            class="relative max-w-7xl mx-auto px-6 lg:px-8 w-full pt-28 pb-20 lg:py-24"
        >
            <div class="flex flex-col items-start gap-6 md:gap-8 max-w-[60ch]">
                <!-- Eyebrow -->
                <div class="overflow-hidden">
                    <span
                        data-i18n="eyebrow"
                        class="inline-block text-xs font-body font-medium tracking-[0.3em] text-accent uppercase"
                    >
                        {t.eyebrow}
                    </span>
                </div>

                <!-- Title -->
                <h1
                    id="not-found-title"
                    data-i18n="title"
                    class="font-heading text-[clamp(2rem,4.5vw,4rem)] leading-[1.1] text-text-primary max-w-[20ch]"
                >
                    {t.title}
                </h1>

                <!-- Subtitle -->
                <p
                    data-i18n="subtitle"
                    class="font-body text-[clamp(1rem,1.4vw,1.25rem)] leading-relaxed text-text-secondary max-w-[45rem]"
                >
                    {t.subtitle}
                </p>

                <!-- CTAs -->
                <div
                    class="flex flex-col sm:flex-row flex-wrap gap-3 sm:gap-4 mt-4 md:mt-6 w-full sm:w-auto"
                >
                    <a
                        data-cta="home"
                        href="/"
                        class="inline-flex items-center justify-center gap-2 font-body font-medium text-sm tracking-wide transition-all duration-300 rounded-full bg-accent text-bg-primary hover:bg-accent-hover px-7 py-3.5 hover:shadow-lg hover:shadow-accent/20 focus:outline-none focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
                    >
                        <span data-i18n="ctaHomeLabel">{t.ctaHomeLabel}</span>
                        <svg
                            aria-hidden="true"
                            class="w-4 h-4"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                            stroke-width="2"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                        </svg>
                    </a>

                    <a
                        data-cta="audit"
                        href="/auditoria-accesibilidad"
                        class="inline-flex items-center justify-center font-body font-medium text-sm tracking-wide transition-all duration-300 rounded-full border border-accent-line text-accent hover:bg-accent-subtle hover:border-border-hover px-7 py-3.5 focus:outline-none focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
                    >
                        <span data-i18n="ctaAuditLabel">{t.ctaAuditLabel}</span>
                    </a>

                    <a
                        data-cta="contact"
                        href="/#contact"
                        class="inline-flex items-center justify-center font-body font-medium text-sm tracking-wide transition-colors duration-300 text-text-secondary hover:text-accent underline underline-offset-[6px] decoration-1 px-2 py-3.5 focus:outline-none focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent rounded-sm"
                    >
                        <span data-i18n="ctaContactLabel"
                            >{t.ctaContactLabel}</span
                        >
                    </a>
                </div>
            </div>
        </div>
    </section>
</BaseLayout>

<!-- Translations + URL map for client-side language swap -->
<script
    is:inline
    type="application/json"
    id="not-found-i18n"
    set:html={JSON.stringify({ es: es.notFound, en: en.notFound })}
/>

<!-- Runs synchronously in <head>-equivalent timing to avoid content flash -->
<script is:inline>
    ;(function () {
        var isEn = window.location.pathname.toLowerCase().startsWith("/en/")
        if (!isEn) return

        var data = JSON.parse(
            document.getElementById("not-found-i18n").textContent,
        ).en

        document.documentElement.lang = "en"
        document.title = data.metaTitle

        document.querySelectorAll("[data-i18n]").forEach(function (el) {
            var key = el.getAttribute("data-i18n")
            if (data[key]) el.textContent = data[key]
        })

        var ctaMap = {
            home: "/en/",
            audit: "/en/accessibility-audit",
            contact: "/en/#contact",
        }
        document.querySelectorAll("[data-cta]").forEach(function (el) {
            var key = el.getAttribute("data-cta")
            if (ctaMap[key]) el.setAttribute("href", ctaMap[key])
        })
    })()
</script>
